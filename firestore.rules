rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() &&
        (request.auth.token.admin == true ||
         request.auth.token.email == 'admin@campus.edu.my');
    }

    match /users/{uid} {
      allow create, read, update, delete: if signedIn() &&
        (request.auth.uid == uid || isAdmin());
    }

    match /items/{itemId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.reporterUid == request.auth.uid;
      allow update: if signedIn() &&
        (resource.data.reporterUid == request.auth.uid || isAdmin()) &&
        request.resource.data.reporterUid == resource.data.reporterUid;
      allow delete: if signedIn() &&
        (resource.data.reporterUid == request.auth.uid || isAdmin());
    }

    match /itemPrivate/{itemId} {
      allow create: if signedIn() &&
        (request.resource.data.ownerUid == request.auth.uid || isAdmin());
      allow read: if signedIn() &&
        (resource.data.ownerUid == request.auth.uid ||
         request.auth.uid in resource.data.get('approvedClaimantUids', []) ||
         isAdmin());
      allow update: if signedIn() &&
        (resource.data.ownerUid == request.auth.uid || isAdmin()) &&
        request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if signedIn() &&
        (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    match /claims/{claimId} {
      allow create: if signedIn() &&
        request.resource.data.claimantUid == request.auth.uid &&
        request.resource.data.itemOwnerUid ==
          get(/databases/$(database)/documents/items/$(request.resource.data.itemId)).data.reporterUid;
      allow read: if signedIn() &&
        (resource.data.claimantUid == request.auth.uid ||
         resource.data.itemOwnerUid == request.auth.uid || isAdmin());
      allow update: if signedIn() &&
        (resource.data.itemOwnerUid == request.auth.uid || isAdmin() ||
         (resource.data.claimantUid == request.auth.uid &&
          resource.data.status == 'Pending' &&
          request.resource.data.status == 'Withdrawn')) &&
        request.resource.data.itemOwnerUid == resource.data.itemOwnerUid &&
        request.resource.data.claimantUid == resource.data.claimantUid &&
        request.resource.data.itemId == resource.data.itemId &&
        request.resource.data.claimantEmail == resource.data.claimantEmail &&
        request.resource.data.claimantName == resource.data.claimantName &&
        request.resource.data.studentId == resource.data.studentId &&
        request.resource.data.contactInfo == resource.data.contactInfo &&
        request.resource.data.proofDescription == resource.data.proofDescription &&
        request.resource.data.linkedLostItemId == resource.data.linkedLostItemId;
      allow delete: if signedIn() &&
        (resource.data.itemOwnerUid == request.auth.uid || isAdmin());
    }

    match /itemChats/{itemId} {
      allow read: if signedIn() &&
        request.auth.uid in resource.data.participantUids;
      allow create: if signedIn() &&
        request.auth.uid in request.resource.data.participantUids &&
        request.resource.data.claimId == itemId &&
        (get(/databases/$(database)/documents/claims/$(itemId)).data.claimantUid == request.auth.uid ||
         get(/databases/$(database)/documents/claims/$(itemId)).data.itemOwnerUid == request.auth.uid ||
         isAdmin());
      allow update: if false;
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if signedIn() && request.auth.uid in
          get(/databases/$(database)/documents/itemChats/$(itemId)).data.participantUids;
        allow create: if signedIn() &&
          request.resource.data.senderUid == request.auth.uid &&
          request.auth.uid in get(/databases/$(database)/documents/itemChats/$(itemId)).data.participantUids;
        allow update, delete: if false;
      }
    }

    match /notifications/{notificationId} {
      allow read, delete: if signedIn() &&
        (resource.data.recipientUid == request.auth.uid || isAdmin());
      allow update: if signedIn() &&
        (resource.data.recipientUid == request.auth.uid || isAdmin()) &&
        request.resource.data.recipientUid == resource.data.recipientUid;
      allow create: if signedIn() &&
        request.resource.data.createdByUid == request.auth.uid;
    }

    match /abuseReports/{reportId} {
      allow create: if signedIn() &&
        request.resource.data.reporterUid == request.auth.uid;
      allow read: if signedIn() &&
        (resource.data.reporterUid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /thankYouMessages/{messageId} {
      allow create: if signedIn() &&
        request.resource.data.fromUid == request.auth.uid;
      allow read: if signedIn() &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid || isAdmin());
      allow update, delete: if false;
    }
  }
}
